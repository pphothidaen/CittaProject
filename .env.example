# ═══════════════════════════════════════════════════════
# Citta Distribution - Environment Configuration
# ═══════════════════════════════════════════════════════
# Quick Start: cp .env.example .env && docker compose up -d

# ─── Version ───
CITTA_VERSION=latest

# ─── Ports (change if conflicts) ───
KERNEL_PORT=8002
GOVERNANCE_PORT=8004
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222

# ─── LLM Provider (local-only by default) ───
CITTA_DEFAULT_PROVIDER=openvino_ovms
CITTA_DEFAULT_MODEL=OpenVINO/DeepSeek-R1-Distill-Qwen-1.5B-int4-ov
CITTA_ROUTE_POLICY_PROFILE=latency_budgeted_cpu
CITTA_EXTERNAL_FIRST=0

# ─── Optional: External LLM API Keys ───
# Uncomment and fill to enable external LLM providers
# GOOGLE_API_KEY=
# OPENAI_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# DEEPSEEK_API_KEY=

# ─── Security ───
CITTA_JWT_SECRET=change-me-to-random-64-hex
AUTH_JWT_SECRET=change-me-to-random-64-hex

# ─── Optional: Telegram Bot ───
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── Optional: LINE Bot ───
# LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET=
